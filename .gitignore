# ─── Environment & Secrets ──────────────────────────────────
secrets/.env
secrets/installed

# ─── Laravel storage (logs, compiled views, cache) ─────────
app/logic/storage/

# ─── Laravel bootstrap cache ────────────────────────────────
app/logic/bootstrap/cache/

# ─── Laravel debug logs ─────────────────────────────────────
app/logic/debug-*.log

# ─── User uploads ──────────────────────────────────────────
assets/uploads/*
!assets/uploads/.gitkeep

# ─── IDE / OS ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
.DS_Store

# ─── Node (if frontend build tooling is added later) ──────
node_modules/
