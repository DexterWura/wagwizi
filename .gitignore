# ─── Environment & Secrets ──────────────────────────────────
.env
**/.env
secrets/.env
secrets/installed

# ─── Laravel storage (logs, compiled views, cache) ─────────
app/logic/storage/

# ─── Laravel bootstrap cache ────────────────────────────────
app/logic/bootstrap/cache/

# ─── Log files ──────────────────────────────────────────────
*.log
app/logic/debug-*.log

# ─── Minified assets (generated by artisan assets:minify) ──
assets/css/*.min.css
assets/js/*.min.js

# ─── User uploads ──────────────────────────────────────────
assets/uploads/*
!assets/uploads/.gitkeep

# ─── IDE / OS ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
.DS_Store

# ─── Node (if frontend build tooling is added later) ──────
node_modules/
