{
    "name": "postai/social-media-manager",
    "description": "PostAI — Multivendor social media management platform built on Laravel",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.0",
        "stripe/stripe-php": "^16.0",
        "razorpay/razorpay": "^2.9",
        "mollie/laravel-mollie": "^3.0",
        "paynow/php-sdk": "^2.0",
        "authorizenet/authorizenet": "^2.0",
        "btcpayserver/btcpayserver-greenfield-php": "^2.0",
        "twilio/sdk": "^8.0",
        "vonage/client": "^4.0",
        "messagebird/php-rest-api": "^4.0",
        "sendgrid/sendgrid": "^8.0",
        "mailjet/mailjet-apiv3-php": "^1.6",
        "phpmailer/phpmailer": "^6.9",
        "google/apiclient": "^2.16",
        "league/flysystem": "^3.0",
        "lcobucci/jwt": "^5.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "App\\Controllers\\": "controllers/",
            "App\\Models\\": "models/",
            "App\\Services\\": "services/",
            "App\\Jobs\\": "Jobs/",
            "App\\Utils\\": "utils/",
            "App\\Providers\\": "providers/",
            "App\\Http\\": "Http/",
            "App\\Console\\": "Console/",
            "Database\\Migrations\\": "database/migrations/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.2.28"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "test": "phpunit -c phpunit.xml"
    }
}
